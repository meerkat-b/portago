#!/usr/bin/env bash
set -euo pipefail

# Resolve the real location of this script (handles symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
PORTAGO_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

# Point all XDG paths into the portago directory so nvim is fully self-contained.
# NVIM_APPNAME=config tells nvim to look for config under $XDG_CONFIG_HOME/config/
export XDG_CONFIG_HOME="$PORTAGO_DIR"
export XDG_DATA_HOME="$PORTAGO_DIR/data"
export XDG_STATE_HOME="$PORTAGO_DIR/state"
export XDG_CACHE_HOME="$PORTAGO_DIR/cache"
export NVIM_APPNAME="config"

exec nvim "$@"
